generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tests     Test[]
  apiKeys   ApiKey[]
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String   @default("Default")
  projectId String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Test {
  id          String   @id @default(cuid())
  name        String
  projectId   String
  fingerprint String   // CSS selector or element identifier
  contentType String   @default("text") // text, button, html, hero, image
  goal        String   // click, pageview, scroll, custom
  goalTarget  String   // selector for click, url for pageview, etc.
  status      String   @default("draft") // draft, live, paused, completed
  winnerId    String?  // variant ID of declared winner
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  variants    Variant[]
}

model Variant {
  id        String   @id @default(cuid())
  testId    String
  name      String   // "Control", "Variant A", "Variant B", etc.
  content   String   // text content, or JSON for complex types (button, hero, html)
  traffic   Int      @default(50) // percentage 0-100
  metadata  String?  // JSON: { rationale, model, strategy, scores }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  test      Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  events    Event[]
}

model Event {
  id        String   @id @default(cuid())
  variantId String
  type      String   // "view", "conversion"
  userId    String   // anonymous hashed user id
  metadata  String?  // JSON: { device, referrer, sessionId, etc. }
  createdAt DateTime @default(now())
  variant   Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, type])
  @@index([userId])
}
